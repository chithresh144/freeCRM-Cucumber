{
    "compilerOptions": {
            "target": "ES2020",
            "module": "CommonJS",
            "moduleResolution": "node",
            "resolveJsonModule": true,
            "esModuleInterop": true,
            "strict": true,
            "ignoreDeprecations": "6.0",
            "moduleDetection": "force",
            "types":["node"],
            "allowSyntheticDefaultImports": true
 
        }
}
